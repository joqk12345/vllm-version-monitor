{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["passed", "reports"],
  "properties": {
    "passed": {"const": true},
    "reports": {"type": "object", "minProperties": 2, "additionalProperties": {"type": "object", "required": ["page_count", "size", "sha256", "missing_terms", "rendered_pages"], "properties": {"page_count": {"type": "integer", "minimum": 1}, "size": {"type": "integer", "minimum": 4000}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "missing_terms": {"type": "array", "maxItems": 0}, "rendered_pages": {"type": "array", "minItems": 1}}}}
  }
}
