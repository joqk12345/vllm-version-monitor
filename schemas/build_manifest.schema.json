{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "project", "cutoff", "source_mode", "latest_stable", "artifacts"],
  "properties": {
    "schema_version": {"const": 1},
    "project": {"type": "string", "minLength": 1},
    "cutoff": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "source_mode": {"type": "string", "minLength": 1},
    "latest_stable": {"type": "string", "minLength": 1},
    "artifacts": {"type": "array", "minItems": 4, "items": {"type": "object", "required": ["path", "sha256", "bytes"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "bytes": {"type": "integer", "minimum": 1}}}}
  }
}
